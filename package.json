{
  "name": "nivaas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "validate-data": "tsx scripts/validate-data.ts",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > lib/db/types.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.45.0",
    "clsx": "^2.1.1",
    "next": "14.2.5",
    "posthog-js": "1.148.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^3.5.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vercel/og": "0.6.2",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "husky": "9.0.11",
    "lint-staged": "15.2.7",
    "postcss": "8.4.38",
    "prettier": "3.3.2",
    "tailwindcss": "3.4.4",
    "tsx": "4.16.2",
    "typescript": "5.5.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md,mdx}": [
      "prettier --write"
    ]
  }
}
